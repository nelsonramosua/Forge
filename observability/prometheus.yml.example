## Reference configuration only.
## Production deployments install /etc/prometheus/prometheus.yml from the Jinja2 template in infra/ansible/templates/prometheus.yml.j2.

global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - alerts.yml

scrape_configs:
  - job_name: forge-control-plane
    static_configs:
      - targets:
          - 127.0.0.1:8080

  - job_name: forge-agent-exporters
    static_configs:
      - targets:
          - WORKER_PRIVATE_IP:9108  # placeholder for the worker address in your deployment

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - 127.0.0.1:9093