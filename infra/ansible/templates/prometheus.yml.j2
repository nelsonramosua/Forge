global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/alerts.yml

scrape_configs:
  - job_name: forge-control-plane
    static_configs:
      - targets:
          - "127.0.0.1:8080"

  - job_name: forge-agent-exporters
    static_configs:
      - targets:
{% for host in groups['workers'] %}
          - "{{ hostvars[host].forge_agent_address }}:9108"
{% endfor %}

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - "127.0.0.1:9093"
