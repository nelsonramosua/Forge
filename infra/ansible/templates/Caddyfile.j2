{
	admin 127.0.0.1:2019
	email admin@{{ forge_base_domain }}
	{% if forge_caddy_dns_cloudflare_enabled | bool %}
	acme_dns cloudflare {env.CF_API_TOKEN}
	{% endif %}
	on_demand_tls {
		ask http://127.0.0.1:8080/api/v1/tls/ask
	}
}

{{ forge_base_domain }} {
	encode zstd gzip
	# /metrics is scraped directly from the control plane on 127.0.0.1:8080.
	@metrics path /metrics
	respond @metrics 404
	@tlsAsk path /api/v1/tls/ask
	respond @tlsAsk 404
	reverse_proxy 127.0.0.1:8080
}

http:// {
	redir https://{host}{uri} permanent
}

https:// {
	tls {
		on_demand
	}
}
