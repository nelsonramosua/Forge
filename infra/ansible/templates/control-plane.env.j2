FORGE_ADDR=:8080
FORGE_DB_PATH=/var/lib/forge/forge.db
FORGE_WORK_DIR=/var/lib/forge/work
FORGE_BASE_DOMAIN={{ forge_base_domain }}
FORGE_CADDY_ADMIN_URL=http://127.0.0.1:2019
FORGE_APP_PORT_START=20000
FORGE_APP_PORT_END=39999
FORGE_ALLOWED_REPOS={{ forge_allowed_repos | default([]) | join(',') }}
FORGE_ALLOWED_BRANCHES={{ forge_allowed_branches | default(['main']) | join(',') }}
FORGE_MAX_SCHEDULE_BATCH={{ forge_max_schedule_batch | default(20) }}
FORGE_MAX_TASKS_PER_AGENT={{ forge_max_tasks_per_agent | default(1) }}
FORGE_MASTER_KEY={{ vault_forge_master_key }}
FORGE_AGENT_TOKEN={{ vault_forge_agent_token }}
FORGE_ADMIN_TOKEN={{ vault_forge_admin_token }}
FORGE_GITHUB_WEBHOOK_SECRET={{ vault_forge_github_webhook_secret }}
